SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional: public site URL (metadata, newsletter links)
APP_BASE_URL=https://your-domain.com

# Weekly pipeline (weeklyPipeline.ts): csak akkor true, ha tudatosan kéred
# AUTO_PUBLISH_LATEST_DRAFT=true
# SEND_NEWSLETTER_AFTER_PUBLISH=true

# Resend (sendNewsletter.ts / pipeline utolsó lépés)
# RESEND_API_KEY=
# RESEND_FROM=Budapest Signal <newsletter@your-domain.com>
# NEWSLETTER_WEB_BASE_URL=https://your-domain.com
# Pause ms between each recipient (rate limit)
# NEWSLETTER_BATCH_PAUSE_MS=120

# Full-agency cycle output links
# APP_BASE_URL=https://your-domain.com

# Social queue runner: default dry-run=true (marks posted without external API call)
# SOCIAL_POST_DRY_RUN=true
# PIPELINE_DISABLE_EXTERNAL_POSTS=false
# SOCIAL_WEBHOOK_SECRET=shared-hmac-secret
# SOCIAL_LINKEDIN_WEBHOOK_URL=
# SOCIAL_X_WEBHOOK_URL=
# SOCIAL_FACEBOOK_WEBHOOK_URL=
# SOCIAL_TELEGRAM_WEBHOOK_URL=

# Circuit breaker: auto-deactivate source after N consecutive failures
# RSS_SOURCE_FAIL_DISABLE_THRESHOLD=3

# Newsletter lock / telemetry
# NEWSLETTER_SEND_LOCK_MINUTES=30

# Optional ops alerts
# ALERT_WEBHOOK_URL=
# ALERT_TELEGRAM_WEBHOOK_URL=
