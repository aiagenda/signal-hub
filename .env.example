# Budapest Signal — frontend (TanStack / Vite). Copy to `.env` locally.

# Supabase project (Settings → API): use anon key in the browser only.
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Admin: add invited e-mails to auth + optional public.admin_emails (SQL) or profiles.role = admin.
# Magic link redirect URL: Supabase Auth URL config must allow http://localhost:5173/admin and production /admin

# Canonical URLs, OG tags, sitemap (no trailing slash). Production: https://your-domain.com
VITE_PUBLIC_SITE_URL=http://localhost:5173

# Use mock newsletter data instead of Supabase (local demo without DB).
# VITE_USE_MOCK_EDITIONS=true

# Optional: default social share image path (served from /public).
# VITE_OG_IMAGE_PATH=/og-default.svg

# Optional analytics (pick one or both; disclose in privacy copy).
# VITE_PLAUSIBLE_DOMAIN=budapestsignal.com
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
